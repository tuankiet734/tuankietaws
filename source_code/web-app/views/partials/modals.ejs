  <!-- Add Customer Modal -->
  <div id="customer-modal" class="modal">
    <div class="modal-content">
      <h3 data-i18n="modal_add_customer_title">Thêm Khách Hàng Mới</h3>
      <form id="customer-form">
        <div class="form-group">
          <label for="customer-name-input" data-i18n="modal_cust_name">Họ và Tên:</label>
          <input type="text" id="customer-name-input" required class="select-control" placeholder="Nhập họ và tên..." data-i18n="modal_cust_name_placeholder">
        </div>
        <div class="form-group">
          <label for="customer-age-input" data-i18n="modal_cust_age">Tuổi:</label>
          <input type="number" id="customer-age-input" required min="1" max="120" class="select-control" placeholder="Nhập tuổi..." data-i18n="modal_cust_age_placeholder">
        </div>
        <div class="form-group">
          <label for="customer-gender-input" data-i18n="modal_cust_gender">Giới tính:</label>
          <select id="customer-gender-input" required class="select-control">
            <option value="Male" data-i18n="modal_cust_gender_male">Nam (Male)</option>
            <option value="Female" data-i18n="modal_cust_gender_female">Nữ (Female)</option>
            <option value="Non-binary" data-i18n="modal_cust_gender_other">Khác (Non-binary)</option>
          </select>
        </div>
        <div class="form-group">
          <label for="customer-country-input" data-i18n="modal_cust_country">Quốc gia:</label>
          <input type="text" id="customer-country-input" required class="select-control" placeholder="Ví dụ: Vietnam, USA..." data-i18n="modal_cust_country_placeholder">
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-primary" data-i18n="modal_btn_create">Thêm mới</button>
          <button type="button" id="btn-cancel-customer" class="btn-secondary" data-i18n="modal_btn_cancel">Hủy</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Create Discount Modal -->
