          </div>
        </div>

        <!-- Block 1: Existing Product Selector -->
        <div id="import-existing-block">
          <div class="form-group" style="margin-bottom: 12px;">
            <label for="import-sku-search" data-i18n="modal_import_search_label">Tìm kiếm SKU / Tên sản phẩm:</label>
            <input type="text" id="import-sku-search" class="select-control" placeholder="Gõ để tìm kiếm mặt hàng có sẵn..." data-i18n="modal_import_search_placeholder">
          </div>
          <div class="form-group" style="margin-bottom: 15px;">
            <label for="import-sku-input" data-i18n="modal_import_sku">Chọn SKU sản phẩm:</label>
            <select id="import-sku-input" class="select-control"></select>
          </div>
